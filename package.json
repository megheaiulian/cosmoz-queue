{
  "name": "@neovici/cosmoz-queue",
  "version": "2.11.3",
  "description": "A reusable queue component for master-detail views with list, split, and queue modes",
  "keywords": [
    "web-components",
    "queue",
    "master-detail",
    "split-view",
    "pion",
    "lit-html"
  ],
  "homepage": "https://github.com/Neovici/cosmoz-queue#readme",
  "bugs": {
    "url": "https://github.com/Neovici/cosmoz-queue/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neovici/cosmoz-queue.git"
  },
  "license": "Apache-2.0",
  "author": "",
  "main": "dist/index.js",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "lint": "tsc && eslint --cache .",
    "build": "tsc -p tsconfig.build.json",
    "start": "wds",
    "test": "vitest --run",
    "test:unit": "vitest --project=unit --run",
    "test:storybook": "vitest --project=storybook --run",
    "test:watch": "vitest",
    "check:duplicates": "check-duplicate-components",
    "dev": "npm run storybook:start",
    "storybook:start": "storybook dev -p 8000",
    "storybook:build": "storybook build",
    "storybook:deploy": "storybook-to-ghpages",
    "storybook:preview": "npm run storybook:build && http-server -d ./storybook-static/",
    "prepare": "husky",
    "changeset": "changeset"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "types"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./use-queue": "./dist/queue/use-queue.js",
    "./use-tabs": "./dist/queue/use-tabs.js",
    "./use-split": "./dist/queue/use-split.js",
    "./use-data-nav": "./dist/queue/use-data-nav.js",
    "./use-list": "./dist/queue/use-list.js",
    "./util/fetch": "./dist/util/fetch/fetch.js",
    "./actions": "./dist/actions/index.js",
    "./list": "./dist/list/index.js",
    "./list/more": "./dist/list/more/use-more.js",
    "./list/more/render": "./dist/list/more/render-more.js"
  },
  "dependencies": {
    "@neovici/cosmoz-form": "^1.0.1 || ^2.0.0 || ^3.2.0-beta.1",
    "@neovici/cosmoz-omnitable": "^16.0.3 || ^17.0.0 || ^18.6.0",
    "@neovici/cosmoz-router": "^11.2.8",
    "@neovici/cosmoz-slider": "^5.2.1",
    "@neovici/cosmoz-tabs": "^9.3.2",
    "@neovici/cosmoz-utils": "^6.22.0",
    "@pionjs/pion": "^2.10.0",
    "i18next": ">=23.0.0 <27.0.0",
    "lit-html": "^3.3.1",
    "split.js": "^1.6.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/eslintrc": "^2.0.0",
    "@neovici/cfg": "^2.11.0",
    "@neovici/testing": "^2.2.0",
    "@storybook/addon-links": "^10.0.0",
    "@storybook/addon-vitest": "^10.0.0",
    "@storybook/web-components": "^10.0.0",
    "@storybook/web-components-vite": "^10.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.13",
    "@types/split.js": "^1.6.0",
    "@vitest/browser": "^4.0.0",
    "@vitest/browser-playwright": "^4.0.0",
    "esbuild": "^0.27.0",
    "http-server": "^14.1.1",
    "husky": "^9.0.11",
    "jsdom": "^26.0.0",
    "playwright": "^1.60.0",
    "storybook": "^10.0.0",
    "typescript": "^5.4.3",
    "vitest": "^4.0.0"
  }
}
